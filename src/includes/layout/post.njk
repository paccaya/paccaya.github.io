<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://indestructibletype.com/fonts/Besley.css" type="text/css" charset="utf-8">
    <link rel="stylesheet" href="https://indestructibletype.com/fonts/Jost.css" type="text/css" charset="utf-8">
    <link rel="stylesheet" href="/css/styles.css" />
    {% eleventyGoogleFonts 'https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400..800;1,400..800&family=Space+Grotesk:wght@300..700&family=Waiting+for+the+Sunrise&display=swap" rel="stylesheet' %}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/fork-awesome@1.2.0/css/fork-awesome.min.css" integrity="sha256-XoaMnoYC5TH6/+ihMEnospgm0J1PM/nioxbOUdnM8HY=" crossorigin="anonymous">

    <script>
      (function() {
          const savedTheme = localStorage.getItem("theme");
          if (savedTheme) {
              document.documentElement.setAttribute("data-theme", savedTheme);
          } else {
              const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
              document.documentElement.setAttribute("data-theme", prefersDark ? "dark" : "light");
          }
      })();
    </script>

  </head>
  <body>
    <div class="content-wrapper">
      <nav>{% include "partials/navbar.njk" %}</nav>

      <h1>{{ title }}</h1>
      <p>{{ author }}<span style="font-size:12px; margin-left:15px; display: inline-flex; opacity: 0.5;">{% if page.date %}
        {{ page.date | readableDate }}
      {% else %}
        No date available
      {% endif %}</span></p>


      <main>{{ content | safe }}</main>
    </div>

    <footer>{% include "partials/footer.njk" %}</footer>
  </body>
</html>
